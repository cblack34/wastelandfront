---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resource Chest Calculator | Last War: Survival" description="Interactive calculator for Last War: Survival resource chests. Calculate total Gold, Food, Iron and Hero EXP from your Resource Choice Chests and level-tied chests by HQ level.">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">Resource Chest Calculator</h1>
    <p class="text-[#8a96b0] mb-6">Calculate totals from your Resource Choice Chests and regular resource chests. Rewards scale with your HQ/Base level — higher levels = significantly more resources per chest.</p>

    <!-- HQ Reference -->
    <div class="bg-[#1f2937] border border-[#374151] rounded-lg p-4 mb-6">
      <div class="flex items-center gap-3">
        <div>
          <label class="block text-sm font-medium mb-1">Your Current HQ / Base Level</label>
          <input type="number" id="hq-level" value="35" min="1" max="50" class="bg-[#111827] border border-[#4b5563] rounded px-3 py-1.5 w-24 text-center" />
        </div>
        <div class="text-xs text-[#8a96b0] max-w-xs">
          Rewards increase with HQ level. Use your in-game chest preview for the most accurate per-chest amounts.
        </div>
      </div>
    </div>

    <!-- Calculator -->
    <div class="bg-[#1f2937] border border-[#374151] rounded-xl p-6">
      <h2 class="text-xl font-semibold mb-4">Chest Quantities & Rewards</h2>
      
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[#374151] text-left">
              <th class="py-3 pr-4">Rarity</th>
              <th class="py-3 px-4 text-center">Quantity</th>
              <th class="py-3 px-4 text-center">Gold per Chest</th>
              <th class="py-3 px-4 text-right">Gold Subtotal</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#374151]">
            <!-- Legendary / UR -->
            <tr>
              <td class="py-3 pr-4 font-medium text-yellow-400">Legendary / UR</td>
              <td class="py-3 px-4">
                <input type="number" id="qty-legendary" value="1" min="0" class="w-20 bg-[#111827] border border-[#4b5563] rounded px-2 py-1 text-center" />
              </td>
              <td class="py-3 px-4">
                <input type="number" id="gold-legendary" value="3020000" min="0" step="1000" class="w-28 bg-[#111827] border border-[#4b5563] rounded px-2 py-1 text-right" />
              </td>
              <td class="py-3 px-4 text-right font-mono" id="sub-legendary">3,020,000</td>
            </tr>
            <!-- Epic / SSR -->
            <tr>
              <td class="py-3 pr-4 font-medium text-purple-400">Epic / SSR</td>
              <td class="py-3 px-4">
                <input type="number" id="qty-epic" value="205" min="0" class="w-20 bg-[#111827] border border-[#4b5563] rounded px-2 py-1 text-center" />
              </td>
              <td class="py-3 px-4">
                <input type="number" id="gold-epic" value="1000000" min="0" step="1000" class="w-28 bg-[#111827] border border-[#4b5563] rounded px-2 py-1 text-right" />
              </td>
              <td class="py-3 px-4 text-right font-mono" id="sub-epic">205,000,000</td>
            </tr>
            <!-- Rare -->
            <tr>
              <td class="py-3 pr-4 font-medium text-blue-400">Rare</td>
              <td class="py-3 px-4">
                <input type="number" id="qty-rare" value="0" min="0" class="w-20 bg-[#111827] border border-[#4b5563] rounded px-2 py-1 text-center" />
              </td>
              <td class="py-3 px-4">
                <input type="number" id="gold-rare" value="126000" min="0" step="100" class="w-28 bg-[#111827] border border-[#4b5563] rounded px-2 py-1 text-right" />
              </td>
              <td class="py-3 px-4 text-right font-mono" id="sub-rare">0</td>
            </tr>
            <!-- Uncommon -->
            <tr>
              <td class="py-3 pr-4 font-medium text-green-400">Uncommon</td>
              <td class="py-3 px-4">
                <input type="number" id="qty-uncommon" value="0" min="0" class="w-20 bg-[#111827] border border-[#4b5563] rounded px-2 py-1 text-center" />
              </td>
              <td class="py-3 px-4">
                <input type="number" id="gold-uncommon" value="12600" min="0" step="100" class="w-28 bg-[#111827] border border-[#4b5563] rounded px-2 py-1 text-right" />
              </td>
              <td class="py-3 px-4 text-right font-mono" id="sub-uncommon">0</td>
            </tr>
          </tbody>
          <tfoot class="border-t-2 border-[#374151] font-semibold">
            <tr>
              <td class="py-4 pr-4">TOTAL GOLD</td>
              <td></td>
              <td></td>
              <td class="py-4 px-4 text-right text-xl font-mono text-yellow-400" id="total-gold">208,020,000</td>
            </tr>
          </tfoot>
        </table>
      </div>

      <div class="mt-6 text-xs text-[#8a96b0]">
        <strong>Tip:</strong> Update the "Gold per Chest" fields with the exact numbers shown in your in-game inventory when you open a chest preview. This gives the most accurate result for your current HQ level.
      </div>
    </div>

    <!-- Additional Resources Section -->
    <div class="mt-8 bg-[#1f2937] border border-[#374151] rounded-xl p-6">
      <h3 class="font-semibold mb-3">Other Resources (Optional)</h3>
      <p class="text-sm text-[#8a96b0] mb-4">Food, Iron, and Hero EXP also scale. Add estimates if needed.</p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="text-sm">Food per Legendary chest</label>
          <input type="number" id="food-legendary" value="4750000" class="w-full bg-[#111827] border border-[#4b5563] rounded px-3 py-2 mt-1" />
          <div class="text-xs mt-1 text-right" id="food-total">—</div>
        </div>
        <div>
          <label class="text-sm">Iron per Legendary chest</label>
          <input type="number" id="iron-legendary" value="4750000" class="w-full bg-[#111827] border border-[#4b5563] rounded px-3 py-2 mt-1" />
          <div class="text-xs mt-1 text-right" id="iron-total">—</div>
        </div>
        <div>
          <label class="text-sm">Hero EXP per Legendary chest</label>
          <input type="number" id="exp-legendary" value="30520000" class="w-full bg-[#111827] border border-[#4b5563] rounded px-3 py-2 mt-1" />
          <div class="text-xs mt-1 text-right" id="exp-total">—</div>
        </div>
      </div>
    </div>

    <div class="mt-6 p-4 bg-[#111827] rounded-lg text-sm">
      <strong class="text-yellow-400">Pro Tip for Last War: Survival</strong><br>
      Save your Resource Choice Chests (especially UR and SSR) and open them at higher HQ levels for maximum value. Gold is often the biggest bottleneck — prioritize Coin choice on most chests.
    </div>

    <div class="mt-8 text-center">
      <a href="/tools" class="text-sm text-[#60a5fa] hover:underline">← Back to Tools</a>
    </div>
  </div>

  <script>
    function formatNumber(num) {
      return num.toLocaleString();
    }

    function updateTotals() {
      // Gold calculation
      const rarities = ['legendary', 'epic', 'rare', 'uncommon'];
      let totalGold = 0;

      rarities.forEach(rarity => {
        const qty = parseFloat(document.getElementById(`qty-${rarity}`).value) || 0;
        const goldPer = parseFloat(document.getElementById(`gold-${rarity}`).value) || 0;
        const subtotal = qty * goldPer;
        totalGold += subtotal;

        const subEl = document.getElementById(`sub-${rarity}`);
        if (subEl) subEl.textContent = formatNumber(subtotal);
      });

      document.getElementById('total-gold').textContent = formatNumber(totalGold);

      // Optional other resources (using Legendary as base for simplicity)
      const foodPerLeg = parseFloat(document.getElementById('food-legendary').value) || 0;
      const ironPerLeg = parseFloat(document.getElementById('iron-legendary').value) || 0;
      const expPerLeg = parseFloat(document.getElementById('exp-legendary').value) || 0;

      const legQty = parseFloat(document.getElementById('qty-legendary').value) || 0;

      // Simple totals for other resources (only Legendary for demo)
      document.getElementById('food-total').textContent = `~${formatNumber(legQty * foodPerLeg)} Food`;
      document.getElementById('iron-total').textContent = `~${formatNumber(legQty * ironPerLeg)} Iron`;
      document.getElementById('exp-total').textContent = `~${formatNumber(legQty * expPerLeg)} Hero EXP`;
    }

    // Attach listeners
    function attachListeners() {
      const inputs = document.querySelectorAll('input[type="number"]');
      inputs.forEach(input => {
        input.addEventListener('input', updateTotals);
      });

      // Initial calculation
      updateTotals();
    }

    // Boot
    document.addEventListener('DOMContentLoaded', () => {
      attachListeners();
    });
  </script>
</Layout>