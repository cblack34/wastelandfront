---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" noIndex={true}>
  <div class="text-center py-16">
    <h1 class="text-6xl font-bold tracking-tighter mb-4">404</h1>
    <p class="text-xl text-[#8a96b0]">That page doesn’t exist (yet).</p>
    <a href="/" class="inline-block mt-8 text-[#f59e0b] hover:underline">← Back to home</a>
  </div>
</Layout>