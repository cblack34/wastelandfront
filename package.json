{
  "name": "wastelandfront",
  "description": "Practical, no-fluff guides for Last War: Survival — focused on new and mid-game players. Squad building, events, alliance tools, and more.",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "audit:a11y": "lhci autorun --config=.lighthouserc.json",
    "audit:contrast": "lhci autorun --config=.lighthouserc.json --assert.preset=lighthouse:recommended",
    "audit:full": "npm run build && lhci autorun --config=.lighthouserc.json",
    "audit:contrast:tokens": "node scripts/contrast-audit.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.6"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@lhci/cli": "^0.15.1",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4.3.0"
  }
}
